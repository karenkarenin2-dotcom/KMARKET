# Шаблон локальных секретов. Скопируй в .env и заполни.
# .env в git НЕ попадает (см. .gitignore). В GitHub Actions те же имена
# задаются через Settings → Secrets and variables → Actions.

# Blizzard Game Data API — ключи берутся тут: https://develop.battle.net/access/clients
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=

# Telegram-алерты (необязательно; без них всё работает, просто молча)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
