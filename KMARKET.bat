@echo off
chcp 65001 >nul
rem Запуск дашборда KMARKET. Ярлык на рабочем столе указывает сюда.
rem Окно консоли намеренно остаётся открытым: в нём видно адрес и ошибки,
rem а закрытие окна останавливает сервер — это и есть кнопка «выключить».
rem
rem ВАЖНО: pause стоит ВСЕГДА, а не только при ошибке. Молча закрывшееся
rem окно не оставляет никаких следов — если сервер упал или его прибили
rem извне, человек видит лишь исчезнувший терминал и не понимает причины.
title KMARKET
cd /d "%~dp0"

python -m kmarket.web

echo.
if errorlevel 1 (
  echo   Сервер завершился с ошибкой.
  echo   Если жалуется на модули — поставь зависимости:
  echo       pip install -r requirements.txt
) else (
  echo   Сервер остановлен.
)
echo.
pause
